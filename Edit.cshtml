@model SistemaEstagio.Models.Produto

<h1>Editar Produto</h1>
<hr />
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="IdProduto" />
    <div class="form-group mb-3">
        <label>Cliente</label>
        <select asp-for="IdCliente" class="form-control" asp-items="ViewBag.IdCliente"></select>
    </div>
    <div class="form-group mb-3">
        <label>Nome do Produto</label>
        <input asp-for="Nome" class="form-control" required />
    </div>
    <div class="form-group mb-3">
        <label>Valor</label>
        <input asp-for="Valor" class="form-control" type="number" step="0.01" />
    </div>
    <div class="form-group mb-3 form-check">
        <input asp-for="Disponivel" type="checkbox" class="form-check-input" />
        <label class="form-check-label">Disponível</label>
    </div>
    <button type="submit" class="btn btn-warning">Salvar Alterações</button>
    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
</form>